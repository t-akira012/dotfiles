#!/bin/bash

select_window() {
  tmux select-window -t ":$1"
}

select_pane() {
  tmux display-panes
}

direct_action() {
  zsh -ic "$1"
}

omni_search() {
  zsh -ic "__omni-search $1"
}

main() {
  local popup="$HOME/bin/func/fzf-tmux-popup.sh"
  local cmd
  cmd=$("$popup" --input "Omni: ")
  [[ -z "$cmd" ]] && exit 0

  if [[ "$cmd" == "q" ]]; then
    select_pane
  elif [[ "$cmd" =~ ^[0-9]+$ ]]; then
    select_window "$cmd"
  elif [[ ${#cmd} -le 2 ]]; then
    direct_action "$cmd"
  else
    omni_search "$cmd"
  fi
}

main
