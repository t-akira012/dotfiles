#!/bin/bash

select_window() {
  tmux select-window -t ":$1"
}

select_pane() {
  tmux display-panes
}

kill_process() {
  zsh -ic "__omni-fzf-kill-process"
}

send_to_pane() {
  tmux send-keys "$1" Enter
}

direct_action() {
  local resolved
  resolved=$(zsh -ic "whence $1" 2>/dev/null)
  if [[ "$resolved" == __* ]]; then
    zsh -ic "$1"
  else
    send_to_pane "$1"
  fi
}

omni_search() {
  zsh -ic "__omni-engine-search $1"
}

main() {
  local popup="$HOME/bin/omni/popup.sh"
  local cmd
  cmd=$("$popup" --input "Omni: ")
  [[ -z "$cmd" ]] && exit 0

  if [[ "$cmd" == "kill" ]]; then
    kill_process
  elif [[ "$cmd" == "q" ]]; then
    select_pane
  elif [[ "$cmd" =~ ^[0-9]+$ ]]; then
    select_window "$cmd"
  elif [[ ${#cmd} -le 2 ]]; then
    direct_action "$cmd"
  else
    omni_search "$cmd"
  fi
}

main
